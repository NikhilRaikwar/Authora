# Required: Stellar secret key for the paying wallet (starts with S...)
STELLAR_SECRET_KEY=

# Defaults to stellar:testnet - use stellar:pubnet for mainnet
STELLAR_NETWORK=stellar:testnet

# Optional: required for mainnet https://rpc.lightsail.network/
STELLAR_RPC_URL=

# Optional facilitator config (for Stellar x402 testnet support)
# Get your free testnet API key at: https://channels.openzeppelin.com/testnet/gen
X402_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
X402_FACILITATOR_API_KEY=582b072e-27e4-4566-bb9d-4457f896704c  # Required for OpenZeppelin testnet facilitator

# Your testnet public key (the address that receives USDC payments)
SELLER_ADDRESS=

# Optional: MCP server metadata
MCP_SERVER_NAME=authora
MCP_SERVER_VERSION=0.1.0

# Authora Registry Service Configuration
REGISTRY_CONTRACT_ID=   # deployed Soroban registry contract ID
REGISTRY_OPERATOR_KEY=  # operator secret key for record_payment calls

# HTTP Discovery Server Configuration
HTTP_PORT=3001          # port for the HTTP manifest server
