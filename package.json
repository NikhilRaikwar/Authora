{
  "name": "authora",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Universal x402-Enabled MCP Registry for Stellar",
  "scripts": {
    "dev": "concurrently \"npm run start\" \"npm run start:http\"",
    "start": "node --enable-source-maps --import tsx src/index.ts",
    "start:http": "node --enable-source-maps --import tsx src/http-server.ts",
    "seed": "node --enable-source-maps --import tsx scripts/seed-registry.ts",
    "demo-service": "node --enable-source-maps --import tsx scripts/demo-service.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testTimeout=60000",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@stellar/stellar-sdk": "^14.6.1",
    "@x402/core": "^2.5.0",
    "@x402/fetch": "^2.5.0",
    "@x402/stellar": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
